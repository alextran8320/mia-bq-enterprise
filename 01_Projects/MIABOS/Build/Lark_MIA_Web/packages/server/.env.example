# Copy file này thành `.env` (cùng folder) trước khi chạy `npm run dev`.
# `.env` tuyệt đối KHÔNG commit (đã có trong .gitignore).
# `.env.example` LÀ template — KHÔNG bao giờ chứa secret thật.

NODE_ENV=development
PORT=3000

# Neon — copy connection string từ Neon dashboard (xem INTEGRATION_PLAN_LARK_AUTH.md §8).
# Format: postgresql://USER:PASSWORD@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# Generate bằng: openssl rand -hex 32
JWT_SECRET=replace-with-32-byte-hex-secret
JWT_EXPIRES_IN=7d

# Comma-separated origins (FE)
CORS_ORIGINS=http://localhost:5180

# Lark Open Platform — lấy từ Lark Console → app → "Credentials & Basic Info"
# Lark intl: https://open.larksuite.com  |  Feishu CN: https://open.feishu.cn
LARK_API_BASE=https://open.larksuite.com
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=xxx
LARK_AUTO_PROVISION=true

# Comma-separated. User Lark có email trong list này ⇒ auto-provision với role=admin.
ADMIN_EMAILS=

# Haravan internal chat bot (Langflow). Server-only. KHÔNG commit key thật.
HARAVAN_CHAT_BOT_API_KEY=
HARAVAN_CHAT_BOT_BASE_URL=https://flow.aaronnnguyen.me/api/v1
HARAVAN_CHAT_BOT_FLOW_ID=22c07722-072f-437c-a782-90e7d813f2ac
