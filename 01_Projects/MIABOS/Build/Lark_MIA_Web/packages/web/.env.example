# Copy this file to .env.development for local dev.
# All values prefixed with VITE_* are exposed to the browser bundle — never put secrets here.

# Override this if BE chạy port khác. Mặc định Vite proxy /api → http://localhost:3000
VITE_DEV_API_TARGET=http://localhost:3000

# Lark Open Platform App ID (browser bundle — non-secret).
# Lấy từ Lark Console → app → "Credentials & Basic Info"
VITE_LARK_APP_ID=cli_xxx

# Lark JS SDK version (CDN URL được build từ giá trị này).
VITE_LARK_SDK_VERSION=1.5.45
